<div class="post framed">
    <img src="{{user.profileImagePath}}" alt="User avatar">
    <div class="post-body">
        <div class="username">
            <a href="/profile/{{user.userId}}">{{user.firstName}} {{user.lastName}}</a>
        </div>
        <div class="post-date">{{postDate}}</div>
        <div class="post-content">
            {{content}}
        </div>

        <div class="post-actions">
            <!-- Comment Section -->
            <a href="/post/{{postId}}" class="far fa-comment"></a>
            <span class="action-count">{{commentsCount}}</span>

            <!-- Heart/Like Section -->
            <button type="button"
                    class="heart-btn {{#isHearted}}fa{{/isHearted}}{{^isHearted}}far{{/isHearted}} fa-heart"
                    data-postid="{{postId}}"
                    data-isadd="{{^isHearted}}true{{/isHearted}}{{#isHearted}}false{{/isHearted}}">
            </button>
            <span class="action-count">{{heartsCount}}</span>

            <!-- Bookmark Section (AJAX Enabled) -->
            <button type="button"
                    class="bookmark-btn {{#isBookmarked}}fa{{/isBookmarked}}{{^isBookmarked}}far{{/isBookmarked}} fa-bookmark"
                    data-postid="{{postId}}"
                    data-isadd="{{^isBookmarked}}true{{/isBookmarked}}{{#isBookmarked}}false{{/isBookmarked}}"
                    aria-label="Toggle Bookmark">
            </button>
        </div>

        {{#isShowComents}}
            {{> fragments/comments_container}}
        {{/isShowComents}}
    </div>
</div>

<script>
    /**
     * AJAX logic to handle Bookmark and Like toggles without page refresh.
     */
    document.addEventListener('DOMContentLoaded', () => {
        // Select all bookmark and heart buttons
        const actionButtons = document.querySelectorAll('.bookmark-btn, .heart-btn');

        actionButtons.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault(); // Stop standard navigation

                const postId = this.getAttribute('data-postid');
                const isAdd = this.getAttribute('data-isadd');
                // Determine if we are calling /bookmark/ or /heart/
                const actionType = this.classList.contains('bookmark-btn') ? 'bookmark' : 'heart';

                // Send request to your Java Controller in the background
                fetch(`/post/${postId}/${actionType}/${isAdd}`)
                    .then(response => {
                        if (response.ok) {
                            // 1. Toggle visual state (Solid vs Outline)
                            this.classList.toggle('fa');
                            this.classList.toggle('far');

                            // 2. Flip the state for the next click
                            const nextState = (isAdd === 'true') ? 'false' : 'true';
                            this.setAttribute('data-isadd', nextState);

                        } else {
                            alert("Action failed. Are you logged in?");
                        }
                    })
                    .catch(err => console.error("Request failed:", err));
            });
        });
    });
</script>